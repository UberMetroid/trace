#!/bin/sh
# postinst script for trace
set -e

case "$1" in
    configure)
        # Create system user (nobody:users with UID/GID 99/100 to match Unraid layout)
        if ! getent group trace >/dev/null 2>&1; then
            addgroup --system --gid 100 trace 2>/dev/null || true
        fi
        if ! getent passwd trace >/dev/null 2>&1; then
            adduser --system --uid 99 --ingroup trace \
                --home /var/lib/trace \
                --no-create-home \
                --shell /usr/sbin/nologin \
                --gecos "Trace WHOIS APP_TITLE_PLACEHOLDER IP lookup service account" \
                trace 2>/dev/null || true
        fi

        # Create data directory
        mkdir -p /var/lib/trace
        chown trace:trace /var/lib/trace
        chmod 755 /var/lib/trace

        # Create default config file if missing
        if [ ! -f /etc/default/trace ]; then
            cat > /etc/default/trace << 'CFGEOF'
# Default configuration for Trace WHOIS APP_TITLE_PLACEHOLDER IP lookup
# Override any value by uncommenting and editing.
PORT=4404
SITE_TITLE=Trace WHOIS APP_TITLE_PLACEHOLDER IP lookup
TZ=UTC
CFGEOF
            chmod 644 /etc/default/trace
        fi

        echo "==============================================="
        echo "  Trace WHOIS APP_TITLE_PLACEHOLDER IP lookup installed successfully"
        echo "  Config:  /etc/default/trace"
        echo "  Data:    /var/lib/trace"
        echo "  Binary:  /usr/bin/trace"
        echo ""
        echo "  Start manually: trace"
        echo "==============================================="
        ;;
esac

#DEBHELPER#
exit 0
